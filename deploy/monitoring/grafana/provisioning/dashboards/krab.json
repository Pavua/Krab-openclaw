{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Archive DB",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          },
          "unit": "bytes",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "archive.db size",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_archive_db_size_bytes",
          "legendFormat": "size"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "Total messages (archive)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_archive_messages_total",
          "legendFormat": "msgs"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value" },
      "title": "Embedded chunks",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_archive_chunks_embedded_total",
          "legendFormat": "chunks"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes/sec" }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 5 },
      "id": 4,
      "options": { "tooltip": { "mode": "single" } },
      "title": "archive.db growth rate (1h)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(krab_archive_db_size_bytes[1h])",
          "legendFormat": "bytes/sec"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 101,
      "title": "LLM & Routes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "OK" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value" },
      "title": "LLM route status",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_llm_route_ok",
          "legendFormat": "{{ provider }}/{{ model }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 6, "w": 12, "x": 6, "y": 12 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "LLM route latency (p50/p95)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.5, rate(krab_llm_route_latency_seconds_bucket[5m]))",
          "legendFormat": "p50 {{ provider }}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, rate(krab_llm_route_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 {{ provider }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Chat Windows",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percentunit",
          "max": 1
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 19 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Chat window usage",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_chat_windows_active / krab_chat_windows_capacity",
          "legendFormat": "usage"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 19 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Chat windows: active / capacity / messages",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_chat_windows_active",
          "legendFormat": "active"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_chat_windows_capacity",
          "legendFormat": "capacity"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_chat_windows_total_messages",
          "legendFormat": "total_msgs"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "Commands & Swarm",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 26 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Command invocations rate (top commands)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "topk(5, rate(krab_command_invocations_total[5m]))",
          "legendFormat": "{{ command }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Swarm delegations active / blocked",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_swarm_delegations_active_chains",
          "legendFormat": "active_chains"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(krab_swarm_delegations_blocked_total[5m])",
          "legendFormat": "blocked/s"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Memory & Restarts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 33 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Memory validator pending",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_memory_validator_pending",
          "legendFormat": "pending"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 6, "w": 12, "x": 5, "y": 33 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Auto-restart rate by service",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rate(krab_auto_restart_attempts_total[5m])",
          "legendFormat": "{{ service }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 105,
      "title": "Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 120 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 40 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Metrics age (stale if >120s)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "time() - krab_metrics_generated_at",
          "legendFormat": "age"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 40 },
      "id": 14,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value" },
      "title": "Pending reminders",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "krab_reminders_pending_total",
          "legendFormat": "reminders"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["krab", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Krab Overview",
  "uid": "krab-overview-v1",
  "version": 1
}
