# =============================================================================
# Krab AI Userbot — переменные окружения
# Скопируйте в .env и заполните значения. Не коммитьте .env в репозиторий.
# Используется: main, config, model_manager, openclaw_client, ai, web_app и др.
# =============================================================================

# --- Telegram (обязательно; получить на my.telegram.org) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=kraab
# В обычном старте держим 0: relogin только через telegram_relogin.command
TELEGRAM_ALLOW_INTERACTIVE_LOGIN=0

# Опционально: токен бота для fallback-сценариев
TELEGRAM_BOT_TOKEN=

# --- OpenClaw Gateway ---
# Порт gateway API (не путать с browser relay на 18792).
OPENCLAW_URL=http://127.0.0.1:18789
# Токен: приоритет у OPENCLAW_GATEWAY_TOKEN, иначе OPENCLAW_TOKEN
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_TOKEN=sk-nexus-bridge

# --- LM Studio (локальные модели) ---
LM_STUDIO_URL=http://192.168.0.171:1234
LM_STUDIO_API_KEY=
# Короткий TTL read-only snapshot'а для web-панели.
# Уменьшает шум `GET /api/v1/models`, не влияя на load/unload write-path.
WEB_LMSTUDIO_SNAPSHOT_TTL_SEC=10
WEB_LMSTUDIO_SNAPSHOT_TTL_LOADED_SEC=60
WEB_LMSTUDIO_SNAPSHOT_TTL_IDLE_SEC=20
WEB_LMSTUDIO_SNAPSHOT_TTL_DOWN_SEC=5
WEB_RUNTIME_LITE_TTL_SEC=10
WEB_RUNTIME_LITE_TTL_LOADED_SEC=60
WEB_RUNTIME_LITE_TTL_IDLE_SEC=20
WEB_RUNTIME_LITE_TTL_DOWN_SEC=5
LOCAL_PREFERRED_MODEL=nvidia/nemotron-3-nano
LOCAL_PREFERRED_VISION_MODEL=auto
SINGLE_LOCAL_MODEL_MODE=1

# Таймауты стрима OpenClaw (сек):
# - OPENCLAW_FIRST_CHUNK_TIMEOUT_SEC: первый токен для текста;
# - OPENCLAW_PHOTO_FIRST_CHUNK_TIMEOUT_SEC: первый токен для фото/vision.
OPENCLAW_CHUNK_TIMEOUT_SEC=180
OPENCLAW_FIRST_CHUNK_TIMEOUT_SEC=420
OPENCLAW_PHOTO_FIRST_CHUNK_TIMEOUT_SEC=540
USERBOT_MAX_OUTPUT_TOKENS=1200
USERBOT_PHOTO_MAX_OUTPUT_TOKENS=420
# Фото-path userbot в auto-vision режиме по умолчанию отправляем в cloud vision,
# чтобы не выгружать текстовую локальную модель под маленький VL fallback.
USERBOT_FORCE_CLOUD_FOR_PHOTO=1
# Нативный local-direct путь LM Studio:
# reasoning отключаем только для наших API-вызовов, не меняя UI-поведение модели.
# Если понадобится вернуть "мышление" в этом канале — поставь `on` или `auto`.
LM_STUDIO_NATIVE_REASONING_MODE=off
LM_STUDIO_NATIVE_AUTO_CONTINUE_MAX_ROUNDS=2
LM_STUDIO_NATIVE_OUTPUT_CAP_MARGIN=8
# Runtime reminders/cron в userbot-контуре (рекомендуется держать включенным).
SCHEDULER_ENABLED=1
DEFERRED_ACTION_GUARD_ENABLED=1

# --- Соседние сервисы экосистемы ---
# Krab Voice Gateway
VOICE_GATEWAY_URL=http://127.0.0.1:8090
KRAB_VOICE_API_KEY=
VOICE_GATEWAY_TIMEOUT_SEC=2.5

# Krab Ear backend
# Если используешь IPC-режим Krab Ear (по умолчанию) — URL можно оставить пустым.
KRAB_EAR_BACKEND_URL=
KRAB_EAR_SOCKET_PATH=~/Library/Application Support/KrabEar/krabear.sock
KRAB_EAR_TIMEOUT_SEC=2.5

# --- Gemini (облачный fallback) ---
GEMINI_API_KEY=

# Модель по умолчанию (например google/gemini-pro-latest)
MODEL=google/gemini-pro-latest
# Режим force_cloud: 1/true/yes — только облако, без fallback на LM Studio (Фаза 2.2)
FORCE_CLOUD=0

# --- Дополнительные API (опционально) ---
BRAVE_SEARCH_API_KEY=
GITHUB_TOKEN=
FIRECRAWL_API_KEY=
CONTEXT7_API_KEY=

# --- MCP / Browser tooling (опционально, но рекомендовано) ---
# OpenClaw browser relay по умолчанию поднимает debuggable Chrome на 18800.
MCP_OPENCLAW_BROWSER_URL=http://127.0.0.1:18800
# Обычный Chrome-профиль пользователя через Remote Debugging.
MCP_CHROME_PROFILE_BROWSER_URL=http://127.0.0.1:9222
# 1/true/yes: автоматически запускать отдельный OpenClaw relay Chrome при старте Krab.
# По умолчанию выключено, чтобы не открывать automation-окно без явной необходимости.
OPENCLAW_BROWSER_AUTOSTART=0

# --- Лимиты и производительность ---
MAX_RAM_GB=24

# --- Логирование ---
LOG_LEVEL=INFO

# --- Доступ и триггеры ---
# Список username через запятую (без @)
ALLOWED_USERS=pablito,admin
# Префиксы для вызова ассистента
TRIGGER_PREFIXES=!краб,@краб,/краб,Краб,,краб,

# --- Честный автоответчик (опционально) ---
# 1/true/yes: в первом ответе нового чата добавляет короткий дисклеймер.
AI_DISCLOSURE_ENABLED=0
AI_DISCLOSURE_TEXT=Я автоассистент Краб 🦀. Пишу от имени владельца и могу помочь по его задачам.
