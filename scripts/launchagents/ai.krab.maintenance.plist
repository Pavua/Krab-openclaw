    <string>ai.krab.maintenance</string>

    <key>Comment</key>
    <string>Krab Weekly Maintenance — VACUUM archive.db, log rotation, sync docs</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd /Users/pablito/Antigravity_AGENTS/Краб && /Users/pablito/Antigravity_AGENTS/Краб/venv/bin/python scripts/maintenance_weekly.py --execute && /Users/pablito/Antigravity_AGENTS/Краб/venv/bin/python scripts/backup_archive_db.py && /Users/pablito/Antigravity_AGENTS/Краб/venv/bin/python scripts/sync_docs.py</string>
