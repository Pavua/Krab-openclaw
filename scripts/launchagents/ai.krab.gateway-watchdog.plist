<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        External watchdog для ai.openclaw.gateway.
        Проверяет каждые 5 минут что LaunchAgent не booted out.
        Если отсутствует в launchctl list → launchctl load -w + Telegram alert.

        Install:
          cp scripts/launchagents/ai.krab.gateway-watchdog.plist ~/Library/LaunchAgents/
          launchctl load -w ~/Library/LaunchAgents/ai.krab.gateway-watchdog.plist
    -->
    <key>Label</key>
    <string>ai.krab.gateway-watchdog</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/pablito/Antigravity_AGENTS/Краб/scripts/openclaw_gateway_watchdog.sh</string>
    </array>

    <!-- 5 минут = 300 sec -->
    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/Users/pablito/Antigravity_AGENTS/Краб</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/pablito</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/krab_gateway_watchdog/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/krab_gateway_watchdog/stderr.log</string>

    <key>KeepAlive</key>
    <false/>

    <key>LowPriorityIO</key>
    <true/>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
